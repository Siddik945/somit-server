{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2021",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    // 🔥 IMPORTANT FIX
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["./generated/prisma"]
    }
  },
  "include": ["src", "generated/prisma", "prisma"],
  "exclude": ["node_modules", "dist"]
}
