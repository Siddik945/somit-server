{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2021",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    // 🔥 IMPORTANT FIX
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src", "generated/prisma"],
  "exclude": ["node_modules", "dist"]
}
